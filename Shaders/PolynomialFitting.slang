float GetNode(int i)
{
#if POLYNOMIAL_DEGREE > MAX_DEGREE_IMPLEMENTED
    #error Cannot implement fitting and queries as the requested degree is higher than what is implemented.
#endif
#if NODE_TYPE_FOR_FITTING == NORMALIZED_CHEBYSHEV_NODES
    return NormalizedChebyshevNodes[nodeOffsetArray[POLYNOMIAL_DEGREE - 1] + i];
#elif NODE_TYPE_FOR_FITTING == CHEBYSHEV_NODES
    return ChebyshevNodes[nodeOffsetArray[POLYNOMIAL_DEGREE - 1] + i];
#endif
}

// Convenience function to retrive the j-th sample's weight when computing the i-th
// degree POLYNOMIAL_DEGREE polynomial fit to a collection of samples.
#ifdef EFT_FITTING
float2 GetFittingCoefficient(int i, int j)
#else
float GetFittingCoefficient(int i, int j)
#endif
{
#if SELECTED_BASIS == BASIS_ID_BERNSTEIN
    return NormalizedBernsteinChebyshevFitting[fittingOffsetArray[POLYNOMIAL_DEGREE - 1] + i * (POLYNOMIAL_DEGREE + 1) + j];
#else // Monomial basis
    #if NODE_TYPE_FOR_FITTING == NORMALIZED_CHEBYSHEV_NODES
        return NormalizedMonomialChebyshevFitting[fittingOffsetArray[POLYNOMIAL_DEGREE - 1] + i * (POLYNOMIAL_DEGREE + 1) + j];
    #elif NODE_TYPE_FOR_FITTING == CHEBYSHEV_NODES
        return MonomialChebyshevFitting[fittingOffsetArray[POLYNOMIAL_DEGREE - 1] + i * (POLYNOMIAL_DEGREE + 1) + j];
    #endif
#endif
}

Polynomial interpolatePolynomial(float samples[POLYNOMIAL_DEGREE + 1], int degree = POLYNOMIAL_DEGREE)
{
    Polynomial poly;
    [[unroll]]
    for (int i = 0; i <= degree; ++i)
    {
    #if defined(EFT_FITTING) 
        /* Based on Ogita, Rump and Oishi in double the working precision
        float2 res = {0.0, 0.0};
        float corr = 0.0;
        [[unroll]]
        for (int j = 0; j <= degree; ++j)
        {
            float2 coeff = GetFittingCoefficient(i, j);

            float2 prod = twoProd(coeff.x, samples[j]);
            float2 prod_lo = twoProd(coeff.y, samples[j]);
            prod = dsAdd(prod, prod_lo);

            res = dsAdd(res, prod);
        }
        poly.coeffs[i] = res.x;
        //*/
        //* Error-Free Transformations and ill-conditioned problems, Siegfried M. Rump
        // Generate summands
        float p[2*POLYNOMIAL_DEGREE+2];
        [[unroll]]
        for (int j = 0; j <= degree; ++j)
        {
            float2 coeff = GetFittingCoefficient(i, j);

            float2 prod = twoProd(coeff.x, samples[j]);
            float2 prod_lo = twoProd(coeff.y, samples[j]);
            prod = dsAdd(prod, prod_lo);

            p[2*j] = prod.x;
            p[2*j+1] = prod.y;
        }
        // sumK
        const static int KK = 10; 
        for (int k = 0; k < KK; ++k)
        {
            // Vecsum
            [[unroll]]
            for (int j = 1; j < 2*degree+2; ++j)
            {
                float2 sum = twoSum(p[j-1], p[j]);
                p[j] = sum.x;  // high bits
                p[j-1] = sum.y; // low bits
            }
        }
        // sum everything
        poly.coeffs[i] = 0.0;
        [[unroll]]
        for (int j = 0; j < 2*degree+2; ++j)
        {
            poly.coeffs[i] += p[j];
        }
        //*/
    #else
        poly.coeffs[i] = 0.0;
        [[unroll]]
        for (int j = 0; j <= degree; ++j)
        {
            poly.coeffs[i] += GetFittingCoefficient(i, j) * samples[j];
        }
    #endif
    }
    return poly;
}

Polynomial fitPolynomial(Ray ray)
{
    float samples[POLYNOMIAL_DEGREE + 1];
    [[unroll]]
    for (int i = 0; i <= POLYNOMIAL_DEGREE; ++i) {
        float node = GetNode(i);
        samples[i] = SURFACE_FUNCTION(ray.atNormalized(node));
    }
    /*/ Normalization
    float max_s = 0.0;
    for (int i = 0; i <= POLYNOMIAL_DEGREE; ++i)
    {
        max_s = max(max_s, abs(samples[i]));
    }
    max_s = exp2((int)ceil(log2(max_s)));
    for (int i = 0; i <= POLYNOMIAL_DEGREE; ++i)
    {
        samples[i] /= max_s;
    }
    //*/
    Polynomial poly = interpolatePolynomial(samples);

#if DEBUG_MODE == DEBUG_POLY_AT_SAMPLES
    float max_err = 0.0;
    [[unroll]]
    for (int i = 1; i < POLYNOMIAL_DEGREE; ++i) {
        float node = GetNode(i);
        float f_val = SURFACE_FUNCTION(ray.atNormalized(node)); // Original function value
        float p_val = poly.at(node);// * max_s;                 // Polynomial approximation value
        float rel_err = abs((f_val - p_val)); // absolute error
        max_err = max(max_err, rel_err);
    }
    DEBUG_COLOR = float3(smoothstep(0, errorThreshold, max_err), 0, 0); // convert errors to color for visualization
#endif

    return poly;
}

#endif // POLYNOMIAL_FITTING
